<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lest.modules.project.mapper.MilestoneMapper">

    <resultMap type="com.lest.modules.project.domain.Milestone" id="MilestoneResult">
        <id     property="id"          column="id"          />
        <result property="projectId"   column="project_id"  />
        <result property="name"        column="name"        />
        <result property="description" column="description" />
        <result property="targetDate"  column="target_date" />
        <result property="createTime"   column="created_at"  />
        <result property="updateTime"   column="updated_at"  />
    </resultMap>

    <sql id="selectMilestoneVo">
        select id, project_id, name, description, target_date, created_at, updated_at from milestone where deleted = 0
    </sql>

    <select id="selectById" resultMap="MilestoneResult">
        <include refid="selectMilestoneVo"/> and id = #{id}
    </select>

    <select id="selectByProjectId" resultMap="MilestoneResult">
        <include refid="selectMilestoneVo"/> and project_id = #{projectId} order by target_date asc
    </select>

    <insert id="insert" parameterType="com.lest.modules.project.domain.Milestone" useGeneratedKeys="true" keyProperty="id">
        insert into milestone (project_id, name, description, target_date, created_at, updated_at)
        values (#{projectId}, #{name}, #{description}, #{targetDate}, now(), now())
    </insert>

    <update id="updateById" parameterType="com.lest.modules.project.domain.Milestone">
        update milestone
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="targetDate != null">target_date = #{targetDate},</if>
            updated_at = now()
        </set>
        where id = #{id} and deleted = 0
    </update>

    <update id="deleteById">
        update milestone set deleted = 1 where id = #{id}
    </update>

</mapper>
