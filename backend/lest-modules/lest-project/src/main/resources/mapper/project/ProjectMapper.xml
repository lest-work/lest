<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lest.modules.project.mapper.ProjectMapper">

    <resultMap type="com.lest.modules.project.domain.Project" id="ProjectResult">
        <id     property="id"          column="id"          />
        <result property="name"        column="name"        />
        <result property="description" column="description" />
        <result property="status"      column="status"      />
        <result property="template"    column="template"    />
        <result property="ownerId"     column="owner_id"    />
        <result property="startDate"   column="start_date"  />
        <result property="endDate"     column="end_date"    />
        <result property="createTime"   column="created_at"  />
        <result property="updateTime"   column="updated_at"  />
        <result property="deleted"     column="deleted"     />
    </resultMap>

    <sql id="selectProjectVo">
        select id, name, description, status, template, owner_id, start_date, end_date, created_at, updated_at
        from project where deleted = 0
    </sql>

    <select id="selectById" resultMap="ProjectResult">
        <include refid="selectProjectVo"/> and id = #{id}
    </select>

    <select id="selectByName" resultMap="ProjectResult">
        <include refid="selectProjectVo"/> and name = #{name} limit 1
    </select>

    <select id="selectProjectList" resultMap="ProjectResult">
        <include refid="selectProjectVo"/>
        <if test="name != null and name != ''">
            and name like concat('%', #{name}, '%')
        </if>
        <if test="status != null">
            and status = #{status}
        </if>
        order by created_at desc
    </select>

    <insert id="insert" parameterType="com.lest.modules.project.domain.Project" useGeneratedKeys="true" keyProperty="id">
        insert into project (name, description, status, template, owner_id, start_date, end_date, created_at, updated_at)
        values (#{name}, #{description}, #{status}, #{template}, #{ownerId}, #{startDate}, #{endDate}, now(), now())
    </insert>

    <update id="updateById" parameterType="com.lest.modules.project.domain.Project">
        update project
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
            <if test="template != null">template = #{template},</if>
            <if test="ownerId != null">owner_id = #{ownerId},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            updated_at = now()
        </set>
        where id = #{id} and deleted = 0
    </update>

    <update id="deleteById">
        update project set deleted = 1 where id = #{id}
    </update>

</mapper>
