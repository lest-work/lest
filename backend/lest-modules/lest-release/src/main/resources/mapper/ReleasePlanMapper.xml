<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lest.modules.release.mapper.ReleasePlanMapper">

    <resultMap type="com.lest.modules.release.domain.ReleasePlan" id="ReleasePlanResult">
        <id     property="releasePlanId"  column="release_plan_id"  />
        <result property="projectId"       column="project_id"       />
        <result property="name"            column="name"             />
        <result property="description"     column="description"      />
        <result property="releaseDate"     column="release_date"     />
        <result property="status"         column="status"           />
        <result property="buildNumber"     column="build_number"     />
        <result property="gitTag"          column="git_tag"          />
        <result property="gitBranch"       column="git_branch"       />
        <result property="changelog"      column="changelog"        />
        <result property="createTime"      column="created_at"       />
        <result property="updateTime"      column="updated_at"       />
        <result property="desc"            column="desc"             />
        <result property="releaseType"     column="release_type"     />
        <result property="isDraft"         column="is_draft"         />
        <result property="isStable"        column="is_stable"        />
        <result property="downloadUrl"    column="download_url"     />
        <result property="releaseNotes"    column="release_notes"    />
        <result property="deleted"         column="deleted"          />
    </resultMap>

    <sql id="selectPlanVo">
        select release_plan_id, project_id, name, description, release_date, status, build_number,
               git_tag, git_branch, changelog, created_at, updated_at,
               `desc`, release_type, is_draft, is_stable, download_url, release_notes, deleted
        from release_plan where deleted = 0
    </sql>

    <select id="selectById" resultMap="ReleasePlanResult">
        <include refid="selectPlanVo"/> and release_plan_id = #{releasePlanId}
    </select>

    <select id="selectPlanList" resultMap="ReleasePlanResult">
        <include refid="selectPlanVo"/>
        <if test="projectId != null">and project_id = #{projectId}</if>
        <if test="keyword != null and keyword != ''">and name like concat('%', #{keyword}, '%')</if>
        <if test="status != null">and status = #{status}</if>
        <if test="releaseType != null">and release_type = #{releaseType}</if>
        <if test="isDraft != null">and is_draft = #{isDraft}</if>
        <if test="isStable != null">and is_stable = #{isStable}</if>
        <if test="startDate != null">and release_date &gt;= #{startDate}</if>
        <if test="endDate != null">and release_date &lt;= #{endDate}</if>
        <choose>
            <when test="sortField == 'release_date' and sortOrder == 'asc'">order by release_date asc</when>
            <when test="sortField == 'release_date'">order by release_date desc</when>
            <when test="sortField == 'status' and sortOrder == 'asc'">order by status asc</when>
            <when test="sortField == 'status'">order by status desc</when>
            <otherwise>order by created_at desc</otherwise>
        </choose>
    </select>

    <select id="selectUpcoming" resultMap="ReleasePlanResult">
        <include refid="selectPlanVo"/>
        and release_date &gt;= now()
        and status in (1, 2)
        order by release_date asc
        limit 10
    </select>

    <select id="selectRecent" resultMap="ReleasePlanResult">
        <include refid="selectPlanVo"/>
        <if test="projectId != null">and project_id = #{projectId}</if>
        and status = 3
        order by updated_at desc
        limit #{limit}
    </select>

    <insert id="insert" parameterType="com.lest.modules.release.domain.ReleasePlan" useGeneratedKeys="true" keyProperty="releasePlanId">
        insert into release_plan (project_id, name, description, release_date, status, build_number,
                                  git_tag, git_branch, changelog, created_by, `desc`,
                                  release_type, is_draft, is_stable, download_url, release_notes)
        values (#{projectId}, #{name}, #{description}, #{releaseDate}, #{status}, #{buildNumber},
                #{gitTag}, #{gitBranch}, #{changelog}, #{createdBy}, #{desc},
                #{releaseType}, #{isDraft}, #{isStable}, #{downloadUrl}, #{releaseNotes})
    </insert>

    <update id="updateById" parameterType="com.lest.modules.release.domain.ReleasePlan">
        update release_plan
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="releaseDate != null">release_date = #{releaseDate},</if>
            <if test="status != null">status = #{status},</if>
            <if test="buildNumber != null">build_number = #{buildNumber},</if>
            <if test="gitTag != null">git_tag = #{gitTag},</if>
            <if test="gitBranch != null">git_branch = #{gitBranch},</if>
            <if test="changelog != null">changelog = #{changelog},</if>
            <if test="updatedBy != null">updated_by = #{updatedBy},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
            <if test="desc != null">`desc` = #{desc},</if>
            <if test="releaseType != null">release_type = #{releaseType},</if>
            <if test="isDraft != null">is_draft = #{isDraft},</if>
            <if test="isStable != null">is_stable = #{isStable},</if>
            <if test="downloadUrl != null">download_url = #{downloadUrl},</if>
            <if test="releaseNotes != null">release_notes = #{releaseNotes},</if>
        </set>
        where release_plan_id = #{releasePlanId} and deleted = 0
    </update>

    <update id="deleteById">
        update release_plan set deleted = 1 where release_plan_id = #{releasePlanId}
    </update>

</mapper>
