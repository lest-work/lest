<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lest.modules.task.mapper.TaskWorklogMapper">

    <resultMap type="com.lest.modules.task.domain.TaskWorklog" id="TaskWorklogResult">
        <id     property="taskWorklogId" column="task_worklog_id" />
        <result property="taskId"        column="task_id"        />
        <result property="userId"        column="user_id"        />
        <result property="hours"         column="hours"         />
        <result property="description"  column="description"  />
        <result property="workDate"      column="work_date"     />
        <result property="createBy"       column="create_by"     />
        <result property="createTime"     column="create_time"   />
    </resultMap>

    <insert id="insert" parameterType="com.lest.modules.task.domain.TaskWorklog" useGeneratedKeys="true" keyProperty="taskWorklogId">
        insert into task_worklog (task_id, user_id, hours, description, work_date, create_by, create_time)
        values (#{taskId}, #{userId}, #{hours}, #{description}, #{workDate}, #{createBy}, now())
    </insert>

    <select id="selectByTaskId" resultMap="TaskWorklogResult">
        select task_worklog_id, task_id, user_id, hours, description, work_date, create_by, create_time
        from task_worklog where task_id = #{taskId} order by work_date desc
    </select>

</mapper>
