<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lest.meeting.mapper.MeetingParticipantMapper">
    <resultMap type="com.lest.meeting.domain.MeetingParticipant" id="MeetingParticipantResult">
        <result property="participantId" column="participant_id"/>
        <result property="meetingId" column="meeting_id"/>
        <result property="userId" column="user_id"/>
        <result property="status" column="status"/>
        <result property="responseTime" column="response_time"/>
    </resultMap>

    <select id="selectByMeetingId" resultMap="MeetingParticipantResult">
        select participant_id, meeting_id, user_id, status, response_time from meeting_participant where meeting_id = #{meetingId}
    </select>

    <insert id="insertParticipant" useGeneratedKeys="true" keyProperty="participantId">
        insert into meeting_participant (meeting_id, user_id, status) values (#{meetingId}, #{userId}, #{status})
    </insert>

    <update id="updateParticipant">
        update meeting_participant set status=#{status}, response_time=#{responseTime} where participant_id = #{participantId}
    </update>

    <delete id="deleteByMeetingId">
        delete from meeting_participant where meeting_id = #{meetingId}
    </delete>
</mapper>
