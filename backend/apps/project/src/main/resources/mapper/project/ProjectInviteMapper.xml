<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lest.project.mapper.ProjectInviteMapper">

    <resultMap type="com.lest.project.domain.ProjectInvite" id="ProjectInviteResult">
        <id     property="inviteId" column="invite_id" />
        <result property="projectId" column="project_id" />
        <result property="email"     column="email" />
        <result property="role"      column="role" />
        <result property="token"     column="token" />
        <result property="expiresAt" column="expires_at" />
        <result property="used"      column="used" />
        <result property="usedBy"    column="used_by" />
        <result property="usedAt"    column="used_at" />
    </resultMap>

    <insert id="insert" parameterType="com.lest.project.domain.ProjectInvite" useGeneratedKeys="true" keyProperty="inviteId">
        insert into project_invite (project_id, email, role, token, expires_at, used, used_by, used_at)
        values (#{projectId}, #{email}, #{role}, #{token}, #{expiresAt}, #{used}, #{usedBy}, #{usedAt})
    </insert>

    <select id="selectByToken" parameterType="string" resultMap="ProjectInviteResult">
        select invite_id, project_id, email, role, token, expires_at, used, used_by, used_at
        from project_invite
        where token = #{token}
    </select>

    <update id="updateById" parameterType="com.lest.project.domain.ProjectInvite">
        update project_invite
        set used = #{used}, used_by = #{usedBy}, used_at = #{usedAt}
        where invite_id = #{inviteId}
    </update>

</mapper>
