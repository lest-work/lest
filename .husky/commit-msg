#!/bin/sh
# LEST Platform — Commit Message Hook
# Validates commit messages against Conventional Commits format

# Check if commit is a merge commit or amend
if [ -f "$1" ] && head -1 "$1" | grep -qE "^Merge"; then
  exit 0
fi

# Read the commit message
commit_msg=$(cat "$1")

# Conventional commit regex: <type>(<scope>): <subject>
# Types: feat, fix, docs, refactor, test, chore, style, perf, build, ci, revert
# Scope: optional, alphanumeric + hyphen
# Subject: required, non-empty

if ! echo "$commit_msg" | head -1 | grep -qE "^(feat|fix|docs|refactor|test|chore|style|perf|build|ci|revert)(\([a-z0-9/-]+\))?[!]?: .+"; then
  echo ""
  echo "❌ Invalid commit message format."
  echo ""
  echo "Expected: <type>(<scope>): <subject>"
  echo ""
  echo "Types:     feat, fix, docs, refactor, test, chore, style, perf, build, ci, revert"
  echo "Examples:"
  echo "  feat(task): add kanban drag support"
  echo "  fix(login): captcha not refreshing"
  echo "  docs: update README"
  echo "  chore: upgrade spring boot to 4.0.4"
  echo ""
  exit 1
fi

exit 0
