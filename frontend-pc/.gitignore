.cursor/
.cursor/rules/

# Build artifacts
backend/docker/lest/*/jar/*.jar
frontend-pc/dist/
frontend-h5/dist/

# Runtime data
backend/logs/
backend/docker/minio/data/
backend/docker/nacos/logs/

# Environment
.env
